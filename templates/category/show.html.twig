{% extends 'base.html.twig' %}

{% block meta_title %}
	{{ category.name }}
	—
	{{ posts|length }}
	статей
{% endblock %}

{% block meta_description %}
	Статьи по теме "{{ category.name }}".
	{{ posts|length }}
	материалов: советы, идеи, вдохновение и полезные рекомендации.
{% endblock %}

{% block meta_keywords %}
	{{ category.name }}, блог, статьи, советы, идеи,
	{{ category.name|lower }}
{% endblock %}

{% block canonical_url %}
	{{ url('app_category_show', { slug: category.slug }) }}
{% endblock %}

{% block body %}

	<main
		class="main-content bg-white">

		{# CATEGORY HEADER #}
		<div class="archive-header pt-50 pb-50 bg-3 mb-50">
			<div class="container">
				<div class="widget-header-1 font-primary mb-30">
					<span class="widget-subtitle position-relative text-primary">
						<span class="divider-separator"></span>Категория
					</span>

					<h2 class="widget-title mt-5 mb-30">
						{{ category.name }}
						<sup>{{ posts|length }}
							постов</sup>
					</h2>
				</div>

				<div class="breadcrumb">
					<a href="{{ path('home') }}" rel="nofollow">Главная</a>
					<span></span>
					{{ category.name }}
				</div>
			</div>
		</div>

		<div class="container mb-50">
			<div class="sidebar-widget post-module-1">
				<div
					class="row mb-50">

					{# POSTS LOOP #}
					{% for post in posts %}
						<article class="col-lg-3 col-md-6 mb-50 wow animated fadeIn">
							<figure class="mb-20">
								<a href="{{ path('app_blog_show', { slug: post.slug }) }}">
									<img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
								</a>
							</figure>

							<div class="post-meta mb-10 font-primary text-uppercase">
								{% if post.category %}
									<span>
										<a href="{{ path('app_category_show', { slug: post.category.slug }) }}">
											{{ post.category.name }}
										</a>
									</span>
								{% endif %}
							</div>

							<h5 class="post-title">
								<a href="{{ path('app_blog_show', { slug: post.slug }) }}">
									{{ post.title }}
								</a>
							</h5>
						</article>
					{% else %}
						<p class="text-center">В этой категории пока нет постов.</p>
					{% endfor %}

				</div>

				{# PAGINATION PLACEHOLDER (если понадобится) #}
				{#
				                <div class="view-more text-center wow animated fadeIn">
				                    {{ knp_pagination_render(posts) }}
				                </div>
				                #}

			</div>
		</div>
	</main>

{% endblock %}
