{% extends 'base.html.twig' %}

{% block title %}Личный кабинет
{% endblock %}
{% block meta_title %}Личный кабинет
{% endblock %}
{% block meta_description %}Настройки пользователя
{% endblock %}


{% block body %}
	<section class="account-settings">
		<div class="container">
			<div class="account-shell">
				<div class="account-layout" data-account-dashboard data-active-tab="{{ activeTab }}">
					<aside class="account-sidebar">
						<h2 class="account-sidebar-title">Кабинет</h2>

						<div class="account-sidebar-label">Профиль</div>

						<div class="account-sidebar-avatar">
							<img id="sidebarAvatarPreview" src="{{ user.avatarUrl }}" alt="Аватар пользователя">
						</div>

						<div class="account-nav">
							<button type="button" class="account-nav-btn{% if activeTab == 'profile' %} active{% endif %}" data-tab-target="profile">
								Профиль
							</button>

							<button type="button" class="account-nav-btn{% if activeTab == 'security' %} active{% endif %}" data-tab-target="security">
								Безопасность
							</button>

							<button type="button" class="account-nav-btn{% if activeTab == 'posts' %} active{% endif %}" data-tab-target="posts">
								Мои публикации
							</button>
						</div>
					</aside>

					<div class="account-content">
						{% for message in app.flashes('success') %}
							<div class="alert alert-success">{{ message }}</div>
						{% endfor %}

						{% for message in app.flashes('danger') %}
							<div class="alert alert-danger">{{ message }}</div>
						{% endfor %}

						<div class="account-pane{% if activeTab == 'profile' %} active{% endif %}" data-tab-pane="profile">
							<div class="account-pane-header">
								<h1 class="account-pane-title">Настройки профиля</h1>
								<p class="account-pane-subtitle">Управление личной информацией</p>
							</div>

							<form class="form-contact comment_form mt-20" method="post">
								<input type="hidden" name="_token" value="{{ csrf_token('account_profile') }}">
								<input type="hidden" name="form_type" value="profile">

								<div class="row">
									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<input class="form-control" name="name" type="text" value="{{ user.name }}" placeholder="Имя">
										</div>
									</div>

									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<div class="form-control">{{ user.email }}</div>
										</div>
									</div>

									<div class="col-12 mb-15">
										<div class="form-group">
											<textarea class="form-control w-100" name="bio" rows="6" placeholder="О себе">{{ user.bio }}</textarea>
										</div>
									</div>
								</div>

								<div class="account-avatar-card">
									<h3 class="account-avatar-title">Аватар профиля</h3>

									<div class="account-avatar-preview">
										<img id="avatarPreview" src="{{ user.avatarUrl }}" alt="Аватар">
									</div>

									<div class="mb-3">
										<input type="file" id="avatarInput" accept="image/png,image/jpeg,image/webp" class="form-control">
									</div>

									<input type="hidden" id="avatarToken" value="{{ csrf_token('upload_avatar') }}">

									<input type="hidden" id="avatarUploadUrl" value="{{ path('app_account_avatar_upload') }}">

									<div id="cropperContainer" class="mb-3">
										<img id="cropperImage" src="" alt="Обрезка аватара">
									</div>

									<button type="button" id="saveAvatarBtn" class="button button-contactForm">
										Сохранить аватар
									</button>

									<div id="avatarMessage" class="mt-3"></div>
								</div>

								<div class="form-group mt-20">
									<button type="submit" class="button button-contactForm">
										Сохранить изменения
									</button>
								</div>
							</form>
						</div>

						<div class="account-pane{% if activeTab == 'security' %} active{% endif %}" data-tab-pane="security">
							<div class="account-pane-header">
								<h2 class="account-pane-title">Безопасность</h2>
								<p class="account-pane-subtitle">Смена пароля</p>
							</div>

							<form class="form-contact comment_form mt-20" method="post">
								<input type="hidden" name="_token" value="{{ csrf_token('account_password') }}">
								<input type="hidden" name="form_type" value="password">

								<div class="row">
									<div class="col-12 mb-15">
										<div class="form-group">
											<input class="form-control" name="current_password" type="password" placeholder="Текущий пароль" autocomplete="current-password">
										</div>
									</div>

									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<input class="form-control" name="new_password" type="password" placeholder="Новый пароль" autocomplete="new-password">
										</div>
									</div>

									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<input class="form-control" name="new_password_repeat" type="password" placeholder="Повторите новый пароль" autocomplete="new-password">
										</div>
									</div>
								</div>

								<div class="form-group">
									<button type="submit" class="button button-contactForm">
										Сменить пароль
									</button>
								</div>
							</form>
						</div>

						<div class="account-pane{% if activeTab == 'posts' %} active{% endif %}" data-tab-pane="posts">
							<div class="account-pane-header account-pane-header--actions">
								<h2 class="account-pane-title">Мои публикации</h2>
								{% if is_granted('ROLE_EDITOR') %}
									<a href="{{ path('app_account_post_create') }}" class="btn-new-post">
										<span class="btn-new-post-icon">+</span>
										Новая публикация
									</a>
								{% endif %}
							</div>
							<div class="account-posts-card">
								{% if posts is not empty %}
									<div class="account-posts-table-wrap">
										<table class="account-posts-table">
											<thead>
												<tr>
													<th>Заголовок</th>
													<th>Категория</th>
													<th>Статус</th>
													<th>Дата</th>
													<th style="text-align: right;">Действия</th>
												</tr>
											</thead>
											<tbody>
												{% for post in posts %}
													{% set statusLabel = 'Черновик' %}
													{% set statusClass = 'account-post-status--draft' %}

													{% if post.status is defined %}
														{% if post.status == 'published' %}
															{% set statusLabel = 'Опубликовано' %}
															{% set statusClass = 'account-post-status--published' %}
														{% elseif post.status == 'draft' %}
															{% set statusLabel = 'Черновик' %}
															{% set statusClass = 'account-post-status--draft' %}
														{% elseif post.status == 'pending' %}
															{% set statusLabel = 'На модерации' %}
															{% set statusClass = 'account-post-status--pending' %}
														{% elseif post.status == 'rejected' %}
															{% set statusLabel = 'Отклонено' %}
															{% set statusClass = 'account-post-status--rejected' %}
														{% endif %}
													{% elseif post.isPublished is defined and post.isPublished %}
														{% set statusLabel = 'Опубликовано' %}
														{% set statusClass = 'account-post-status--published' %}
													{% endif %}
													<tr>
														<td>
															<div class="account-post-title">
																<a href="{{ path('app_blog_show', {id: post.id, slug: post.slug}) }}">
																	{{ post.title }}
																</a>
															</div>
														</td>
														<td>
															{% if post.category %}
																<span class="account-category-badge">{{ post.category.name }}</span>
															{% else %}
																<span class="account-post-date">—</span>
															{% endif %}
														</td>
														<td>
															<span class="account-post-status {{ statusClass }}">
																<span class="status-dot"></span>
																{{ statusLabel }}
															</span>
														</td>
														<td>
															<span class="account-post-date">
																{% if post.createdAt %}
																	{{ post.createdAt|date('d.m.Y') }}
																{% else %}
																	—
																{% endif %}
															</span>
														</td>
														<td>
															<div class="account-post-actions">
																<a href="{{ path('app_blog_show', {id: post.id, slug: post.slug}) }}" class="account-post-link">
																	Смотреть
																</a>

																<div class="account-dropdown">
																	<button type="button" class="account-dropdown-btn" data-dropdown-toggle>
																		⋯
																	</button>
																	<div class="account-dropdown-menu">
																		{% if is_granted('ROLE_EDITOR') or app.user == post.author %}
																			<a href="{{ path('app_account_post_edit', {id: post.id}) }}" class="account-dropdown-item">
																				<span class="account-dropdown-icon">✏</span>
																				<span>Редактировать</span>
																			</a>
																		{% endif %}
																	</div>
																</div>
															</div>
														</td>
													</tr>
												{% endfor %}
											</tbody>
										</table>
									</div>
								{% else %}
									<div class="account-posts-empty">
										<div class="account-empty">
											<div class="mb-2 fw-semibold">У вас пока нет публикаций</div>
											<div class="text-muted mb-3">Здесь будут отображаться ваши статьи</div>

											{% if is_granted('ROLE_EDITOR') %}
												<a href="{{ path('app_account_post_create') }}" class="button button-contactForm">
													Создать первую публикацию
												</a>
											{% endif %}
										</div>
									</div>
								{% endif %}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
{% block page_scripts %}{% endblock %}
