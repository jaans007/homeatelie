{% extends 'base.html.twig' %}

{% block title %}Личный кабинет
{% endblock %}
{% block meta_title %}Личный кабинет
{% endblock %}
{% block meta_description %}Настройки пользователя
{% endblock %}

{% block page_styles %}
	{{ parent() }}
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css">

	<style>
		.account-settings {
			padding: 50px 0;
		}
		.account-shell {
			background: #fff;
			border: 1px solid var(--primary-border-color);
			overflow: hidden;
		}
		.account-layout {
			display: grid;
			grid-template-columns: 260px 1fr;
		}
		.account-sidebar {
			border-right: 1px solid var(--primary-border-color);
			padding: 30px;
			background: #fdfdfd;
		}
		.account-sidebar-title {
			font-size: 22px;
			font-weight: 700;
			margin-bottom: 25px;
		}
		.account-sidebar-label {
			font-size: 12px;
			text-transform: uppercase;
			margin-bottom: 10px;
			color: var(--color-muted);
		}
		.account-sidebar-avatar {
			margin-bottom: 25px;
			text-align: center;
		}
		.account-sidebar-avatar img {
			width: 110px;
			height: 110px;
			object-fit: cover;
			border-radius: 50%;
			border: 1px solid var(--primary-border-color);
		}
		.account-nav {
			display: flex;
			flex-direction: column;
			gap: 10px;
		}
		.account-nav-btn {
			border: 0;
			background: none;
			text-align: left;
			color: var(--color-dark);
			cursor: pointer;
			padding: 6px 0;
			transition: 0.2s;
		}
		.account-nav-btn:hover {
			color: var(--color-primary);
		}
		.account-nav-btn.active {
			color: var(--color-primary);
			font-weight: 600;
		}
		.account-content {
			padding: 40px;
		}
		.account-pane {
			display: none;
		}
		.account-pane.active {
			display: block;
		}
		.account-pane-header {
			margin-bottom: 30px;
			border-bottom: 1px solid var(--primary-border-color);
			padding-bottom: 15px;
		}
		.account-pane-header--actions {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 20px;
		}
		.account-pane-title {
			font-size: 22px;
			font-weight: 400;
			margin: 0 0 8px;
		}
		.account-pane-subtitle {
			color: var(--color-muted);
			margin: 0;
		}
		.account-empty {
			border: 1px dashed var(--primary-border-color);
			padding: 20px;
			border-radius: 10px;
		}
		textarea[name="bio"] {
			min-height: 200px;
			resize: vertical;
		}
		.account-avatar-card {
			margin-top: 10px;
			padding: 25px;
			border: 1px solid var(--primary-border-color);
			border-radius: 12px;
			background: #fff;
		}
		.account-avatar-title {
			margin-bottom: 20px;
			font-size: 20px;
			font-weight: 600;
		}
		.account-avatar-preview {
			text-align: center;
			margin-bottom: 20px;
		}
		.account-avatar-preview img {
			width: 140px;
			height: 140px;
			object-fit: cover;
			border-radius: 50%;
			border: 1px solid #ddd;
		}
		#cropperContainer {
			display: none;
			max-width: 500px;
			margin-top: 20px;
		}
		#cropperContainer img {
			max-width: 100%;
		}
		.alert {
			padding: 14px 18px;
			border-radius: 10px;
			margin-bottom: 20px;
			border: 1px solid transparent;
		}
		.alert-success {
			color: #155724;
			background: #d4edda;
			border-color: #c3e6cb;
		}
		.alert-danger {
			color: #721c24;
			background: #f8d7da;
			border-color: #f5c6cb;
		}
		.account-posts-card {
			border: 1px solid var(--primary-border-color);
			border-radius: 16px;
			overflow: visible;
			background: #fff;
		}
		.account-posts-table-wrap {
			overflow-x: auto;
		}
		.account-posts-table {
			width: 100%;
			border-collapse: collapse;
			margin: 0;
		}
		.account-posts-table thead th {
			font-size: 12px;
			font-weight: 700;
			color: var(--color-muted);
			text-transform: uppercase;
			letter-spacing: 0.04em;
			padding: 16px 24px;
			border-bottom: 1px solid var(--primary-border-color);
			background: #fafafa;
			white-space: nowrap;
		}
		.account-posts-table tbody td {
			padding: 18px 24px;
			border-bottom: 1px solid #f1f1f1;
			vertical-align: middle;
		}
		.account-posts-table tbody tr:hover {
			background: #fcfcfc;
		}
		.account-post-title {
			font-size: 16px;
			font-weight: 500;
			margin: 0;
			line-height: 1.4;
		}
		.account-post-title a {
			color: inherit;
			text-decoration: none;
		}
		.account-post-title a:hover {
			color: var(--color-primary);
		}
		.account-category-badge {
			display: inline-flex;
			align-items: center;
			padding: 6px 10px;
			border-radius: 30px;
			border: 1px solid var(--primary-border-color);
			background: #fafafa;
			font-size: 12px;
			line-height: 1;
			white-space: nowrap;
		}
		.account-post-status {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			padding: 5px 10px;
			border-radius: 20px;
			font-size: 13px;
			font-weight: 500;
			white-space: nowrap;
		}
		.status-dot {
			width: 8px;
			height: 8px;
			border-radius: 50%;
		}
		.account-post-status--draft {
			background: #f2f4f7;
			color: #667085;
		}
		.account-post-status--draft .status-dot {
			background: #98a2b3;
		}
		.account-post-status--pending {
			background: #fffaeb;
			color: #b54708;
		}
		.account-post-status--pending .status-dot {
			background: #f79009;
		}
		.account-post-status--published {
			background: #ecfdf3;
			color: #027a48;
		}
		.account-post-status--published .status-dot {
			background: #12b76a;
		}
		.account-post-status--rejected {
			background: #fef3f2;
			color: #b42318;
		}
		.account-post-status--rejected .status-dot {
			background: #f04438;
		}
		.account-post-date {
			font-size: 13px;
			color: var(--color-muted);
			white-space: nowrap;
		}
		.account-post-link {
			font-size: 14px;
			font-weight: 400;
			color: var(--color-dark);
			text-decoration: none;
			transition: 0.2s;
			white-space: nowrap;
		}
		.account-post-link:hover {
			color: var(--color-primary);
			text-decoration: underline;
		}
		.account-post-actions {
			display: flex;
			align-items: center;
			justify-content: flex-end;
			gap: 10px;
			flex-wrap: nowrap;
			position: relative;
		}
		.account-dropdown {
			position: relative;
		}
		.account-dropdown-btn {
			width: 38px;
			height: 38px;
			padding: 0;
			border: 1px solid var(--primary-border-color);
			background: #fff;
			border-radius: 10px;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			font-size: 22px;
			line-height: 1;
			color: #667085;
			transition: 0.2s;
		}
		.account-dropdown-btn:hover {
			background: #f8f9fb;
			border-color: #d7dce3;
			color: #344054;
		}
		.account-dropdown-btn:focus {
			outline: none;
		}
		.account-dropdown-menu {
			position: absolute;
			top: calc(100% + 8px);
			right: 0;
			min-width: 190px;
			padding: 8px;
			background: #fff;
			border: 1px solid #e5e7eb;
			border-radius: 12px;
			box-shadow: 0 12px 30px rgba(16, 24, 40, 0.12);
			display: none;
			z-index: 50;
		}
		.account-dropdown.open .account-dropdown-menu {
			display: block;
		}
		.account-dropdown-item {
			display: flex;
			align-items: center;
			gap: 10px;
			width: 100%;
			padding: 10px 12px;
			border-radius: 8px;
			color: #344054;
			text-decoration: none;
			font-size: 14px;
			font-weight: 500;
			transition: 0.2s;
		}
		.account-dropdown-item:hover {
			background: #f8f9fb;
			color: #101828;
			text-decoration: none;
		}
		.account-dropdown-item-danger {
			color: #d92d20;
		}
		.account-dropdown-item-danger:hover {
			background: #fef3f2;
			color: #b42318;
		}
		.account-dropdown-icon {
			width: 16px;
			text-align: center;
			flex: 0 0 16px;
		}
		.account-posts-empty {
			padding: 30px 24px;
		}
		.btn-new-post {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			padding: 9px 16px;
			font-size: 15px;
			font-weight: 400;
			color: #111;
			background: #f7f7f7;
			border: 1px solid var(--primary-border-color);
			border-radius: 8px;
			text-decoration: none;
			transition: all 0.18s ease;
		}
		.btn-new-post:hover {
			background: #fff;
			color: var(--color-primary);
			border-color: #e0e0e0;
			text-decoration: none;
		}
		.btn-new-post-icon {
			font-size: 16px;
			font-weight: 700;
			line-height: 1;
		}
		@media(max-width: 991px) {
			.account-layout {
				grid-template-columns: 1fr;
			}
			.account-sidebar {
				border-right: 0;
				border-bottom: 1px solid var(--primary-border-color);
			}
			.account-content {
				padding: 25px;
			}
			.account-pane-header--actions {
				flex-direction: column;
				align-items: flex-start;
			}
			.account-posts-table thead th,
			.account-posts-table tbody td {
				padding: 14px 16px;
			}
			.account-post-actions {
				justify-content: flex-start;
			}
			.account-dropdown-menu {
				right: 0;
			}
		}
	</style>
{% endblock %}

{% block body %}
	<section class="account-settings">
		<div class="container">
			<div class="account-shell">
				<div class="account-layout" data-account-dashboard data-active-tab="{{ activeTab }}">
					<aside class="account-sidebar">
						<h2 class="account-sidebar-title">Кабинет</h2>

						<div class="account-sidebar-label">Профиль</div>

						<div class="account-sidebar-avatar">
							<img id="sidebarAvatarPreview" src="{{ user.avatarUrl }}" alt="Аватар пользователя">
						</div>

						<div class="account-nav">
							<button type="button" class="account-nav-btn{% if activeTab == 'profile' %} active{% endif %}" data-tab-target="profile">
								Профиль
							</button>

							<button type="button" class="account-nav-btn{% if activeTab == 'security' %} active{% endif %}" data-tab-target="security">
								Безопасность
							</button>

							<button type="button" class="account-nav-btn{% if activeTab == 'posts' %} active{% endif %}" data-tab-target="posts">
								Мои публикации
							</button>
						</div>
					</aside>

					<div class="account-content">
						{% for message in app.flashes('success') %}
							<div class="alert alert-success">{{ message }}</div>
						{% endfor %}

						{% for message in app.flashes('danger') %}
							<div class="alert alert-danger">{{ message }}</div>
						{% endfor %}

						<div class="account-pane{% if activeTab == 'profile' %} active{% endif %}" data-tab-pane="profile">
							<div class="account-pane-header">
								<h1 class="account-pane-title">Настройки профиля</h1>
								<p class="account-pane-subtitle">Управление личной информацией</p>
							</div>

							<form class="form-contact comment_form mt-20" method="post">
								<input type="hidden" name="_token" value="{{ csrf_token('account_profile') }}">
								<input type="hidden" name="form_type" value="profile">

								<div class="row">
									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<input class="form-control" name="name" type="text" value="{{ user.name }}" placeholder="Имя">
										</div>
									</div>

									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<div class="form-control">{{ user.email }}</div>
										</div>
									</div>

									<div class="col-12 mb-15">
										<div class="form-group">
											<textarea class="form-control w-100" name="bio" rows="6" placeholder="О себе">{{ user.bio }}</textarea>
										</div>
									</div>
								</div>

								<div class="account-avatar-card">
									<h3 class="account-avatar-title">Аватар профиля</h3>

									<div class="account-avatar-preview">
										<img id="avatarPreview" src="{{ user.avatarUrl }}" alt="Аватар">
									</div>

									<div class="mb-3">
										<input type="file" id="avatarInput" accept="image/png,image/jpeg,image/webp" class="form-control">
									</div>

									<input type="hidden" id="avatarToken" value="{{ csrf_token('upload_avatar') }}">

									<input type="hidden" id="avatarUploadUrl" value="{{ path('app_account_avatar_upload') }}">

									<div id="cropperContainer" class="mb-3">
										<img id="cropperImage" src="" alt="Обрезка аватара">
									</div>

									<button type="button" id="saveAvatarBtn" class="button button-contactForm">
										Сохранить аватар
									</button>

									<div id="avatarMessage" class="mt-3"></div>
								</div>

								<div class="form-group mt-20">
									<button type="submit" class="button button-contactForm">
										Сохранить изменения
									</button>
								</div>
							</form>
						</div>

						<div class="account-pane{% if activeTab == 'security' %} active{% endif %}" data-tab-pane="security">
							<div class="account-pane-header">
								<h2 class="account-pane-title">Безопасность</h2>
								<p class="account-pane-subtitle">Смена пароля</p>
							</div>

							<form class="form-contact comment_form mt-20" method="post">
								<input type="hidden" name="_token" value="{{ csrf_token('account_password') }}">
								<input type="hidden" name="form_type" value="password">

								<div class="row">
									<div class="col-12 mb-15">
										<div class="form-group">
											<input class="form-control" name="current_password" type="password" placeholder="Текущий пароль" autocomplete="current-password">
										</div>
									</div>

									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<input class="form-control" name="new_password" type="password" placeholder="Новый пароль" autocomplete="new-password">
										</div>
									</div>

									<div class="col-sm-6 mb-15">
										<div class="form-group">
											<input class="form-control" name="new_password_repeat" type="password" placeholder="Повторите новый пароль" autocomplete="new-password">
										</div>
									</div>
								</div>

								<div class="form-group">
									<button type="submit" class="button button-contactForm">
										Сменить пароль
									</button>
								</div>
							</form>
						</div>

						<div class="account-pane{% if activeTab == 'posts' %} active{% endif %}" data-tab-pane="posts">
							<div class="account-pane-header account-pane-header--actions">
								<h2 class="account-pane-title">Мои публикации</h2>
								{% if is_granted('ROLE_EDITOR') %}
									<a href="{{ path('app_account_post_create') }}" class="btn-new-post">
										<span class="btn-new-post-icon">+</span>
										Новая публикация
									</a>
								{% endif %}
							</div>
							<div class="account-posts-card">
								{% if posts is not empty %}
									<div class="account-posts-table-wrap">
										<table class="account-posts-table">
											<thead>
												<tr>
													<th>Заголовок</th>
													<th>Категория</th>
													<th>Статус</th>
													<th>Дата</th>
													<th style="text-align: right;">Действия</th>
												</tr>
											</thead>
											<tbody>
												{% for post in posts %}
													{% set statusLabel = 'Черновик' %}
													{% set statusClass = 'account-post-status--draft' %}

													{% if post.status is defined %}
														{% if post.status == 'published' %}
															{% set statusLabel = 'Опубликовано' %}
															{% set statusClass = 'account-post-status--published' %}
														{% elseif post.status == 'draft' %}
															{% set statusLabel = 'Черновик' %}
															{% set statusClass = 'account-post-status--draft' %}
														{% elseif post.status == 'pending' %}
															{% set statusLabel = 'На модерации' %}
															{% set statusClass = 'account-post-status--pending' %}
														{% elseif post.status == 'rejected' %}
															{% set statusLabel = 'Отклонено' %}
															{% set statusClass = 'account-post-status--rejected' %}
														{% endif %}
													{% elseif post.isPublished is defined and post.isPublished %}
														{% set statusLabel = 'Опубликовано' %}
														{% set statusClass = 'account-post-status--published' %}
													{% endif %}
													<tr>
														<td>
															<div class="account-post-title">
																<a href="{{ path('app_blog_show', {id: post.id, slug: post.slug}) }}">
																	{{ post.title }}
																</a>
															</div>
														</td>
														<td>
															{% if post.category %}
																<span class="account-category-badge">{{ post.category.name }}</span>
															{% else %}
																<span class="account-post-date">—</span>
															{% endif %}
														</td>
														<td>
															<span class="account-post-status {{ statusClass }}">
																<span class="status-dot"></span>
																{{ statusLabel }}
															</span>
														</td>
														<td>
															<span class="account-post-date">
																{% if post.createdAt %}
																	{{ post.createdAt|date('d.m.Y') }}
																{% else %}
																	—
																{% endif %}
															</span>
														</td>
														<td>
															<div class="account-post-actions">
																<a href="{{ path('app_blog_show', {id: post.id, slug: post.slug}) }}" class="account-post-link">
																	Смотреть
																</a>

																<div class="account-dropdown">
																	<button type="button" class="account-dropdown-btn" data-dropdown-toggle>
																		⋯
																	</button>
																	<div class="account-dropdown-menu">
																		{% if is_granted('ROLE_EDITOR') or app.user == post.author %}
																			<a href="{{ path('app_account_post_edit', {id: post.id}) }}" class="account-dropdown-item">
																				<span class="account-dropdown-icon">✏</span>
																				<span>Редактировать</span>
																			</a>
																		{% endif %}
																	</div>
																</div>
															</div>
														</td>
													</tr>
												{% endfor %}
											</tbody>
										</table>
									</div>
								{% else %}
									<div class="account-posts-empty">
										<div class="account-empty">
											<div class="mb-2 fw-semibold">У вас пока нет публикаций</div>
											<div class="text-muted mb-3">Здесь будут отображаться ваши статьи</div>

											{% if is_granted('ROLE_EDITOR') %}
												<a href="{{ path('app_account_post_create') }}" class="button button-contactForm">
													Создать первую публикацию
												</a>
											{% endif %}
										</div>
									</div>
								{% endif %}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
{% block page_scripts %}
	{{ parent() }}
	<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
	<script src="{{ asset('assets/js/account.js') }}"></script>
{% endblock %}
