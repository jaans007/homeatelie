{% extends 'base.html.twig' %}

{% block title %}Редактирование статьи
{% endblock %}
{% block meta_title %}Редактирование статьи
{% endblock %}
{% block meta_description %}Редактирование публикации
{% endblock %}

{% block body %}
	<main class="main-content bg-white post-create-layout post-edit-layout">
		{{ form_start(form, {
            attr: {
                class: 'js-post-create-form',
                novalidate: 'novalidate'
            }
        }) }}

		<div class="d-none">
			{{ form_widget(form.imageFile, {
                attr: {
                    class: 'js-post-image-input',
                    accept: 'image/*'
                }
            }) }}
		</div>

		<div class="container single-content">
			<div class="entry-header entry-header-style-1 mb-50">

				{{ form_widget(form.title, {
                    attr: {
                        class: 'entry-title-input' ~ (form.title.vars.errors|length ? ' is-invalid' : ''),
                        placeholder: 'Введите заголовок статьи'
                    }
                }) }}

				<div class="post-create-field-error">
					{{ form_errors(form.title) }}
				</div>

				<div class="entry-meta align-items-center meta-2 font-small color-muted mt-20">
					<p class="mb-5">
						<span class="author-avatar">
							<img class="img-circle" src="{{ app.user.avatarUrl }}" alt="{{ app.user.name }}">
						</span>

						<span class="author-name font-weight-bold">
							Автор —
							{{ app.user.name }}
						</span>
					</p>

					<span class="mr-10">Редактирование публикации</span>
					<span class="has-dot">
						{{ post.status == 'published' ? 'Опубликована' : 'Черновик / модерация' }}
					</span>
				</div>
			</div>

			<figure class="image mb-30 m-auto text-center post-create-cover{% if post.image %} has-image{% endif %}{% if form.imageFile.vars.errors|length %} is-invalid{% endif %}" id="postHeroPreview">
				{% if post.image %}
					<img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}" class="post-create-cover-image">
				{% endif %}

				<div class="post-create-hero-upload" id="postHeroUpload">
					<div class="post-create-hero-overlay">
						<span class="post-create-hero-plus">+</span>
						<span class="post-create-hero-text">Изменить обложку статьи</span>
						<span class="post-create-hero-subtext">Нажмите, чтобы выбрать новое изображение</span>
					</div>
				</div>

				<div class="post-meta font-primary text-uppercase rotate-90 top-left post-create-cover-meta">
					<span>Обложка статьи</span>
				</div>
			</figure>

			<div class="post-create-field-error">
				{{ form_errors(form.imageFile) }}
			</div>

			<div class="post-create-meta-box">
				<div class="form-group mb-20">
					{{ form_widget(form.imageAttribution, {
                        attr: {
                            class: 'form-select' ~ (form.imageAttribution.vars.errors|length ? ' is-invalid' : '')
                        }
                    }) }}

					<div class="post-create-field-error">
						{{ form_errors(form.imageAttribution) }}
					</div>

					<small class="text-muted d-block mt-10">
						Выберите, кем создана или откуда взята обложка.
					</small>
				</div>
			</div>

			<div class="post-create-meta-box mb-40">
				<div class="post-create-meta-item">
					{{ form_label(form.category) }}
					{{ form_widget(form.category, {
                        attr: {
                            class: 'js-post-category-select' ~ (form.category.vars.errors|length ? ' is-invalid' : '')
                        }
                    }) }}

					<div class="post-create-field-error">
						{{ form_errors(form.category) }}
					</div>
				</div>
			</div>

			<article class="entry-wraper mb-50">
				<div class="entry-main-content">
					<label class="form-label mb-10">Текст статьи</label>

					<div class="post-create-toolbar-wrap">
						<div class="post-create-toolbar">
							<div class="tiptap-toolbar">
								<button type="button" class="tiptap-btn" data-action="bold" title="Жирный">
									<i data-lucide="bold"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="italic" title="Курсив">
									<i data-lucide="italic"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="underline" title="Подчёркивание">
									<i data-lucide="underline"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="strike" title="Зачёркнутый">
									<i data-lucide="strikethrough"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="h2" title="Заголовок H2">
									<i data-lucide="heading-2"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="h3" title="Заголовок H3">
									<i data-lucide="heading-3"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="bulletList" title="Маркированный список">
									<i data-lucide="list"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="orderedList" title="Нумерованный список">
									<i data-lucide="list-ordered"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="blockquote" title="Цитата">
									<i data-lucide="quote"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="alignLeft" title="Влево">
									<i data-lucide="align-left"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="alignCenter" title="По центру">
									<i data-lucide="align-center"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="alignRight" title="Вправо">
									<i data-lucide="align-right"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="link" title="Ссылка">
									<i data-lucide="link"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="image" title="Изображение">
									<i data-lucide="image"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="undo" title="Отменить">
									<i data-lucide="undo-2"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="redo" title="Повторить">
									<i data-lucide="redo-2"></i>
								</button>
								<button type="button" class="tiptap-btn" data-action="youtube" title="Вставить видео">
									<i data-lucide="youtube"></i>
								</button>
							</div>
						</div>
					</div>

					<input type="file" id="postInlineImageInput" accept="image/*" hidden>

					<div id="postEditor" class="post-create-editor{{ form.content.vars.errors|length ? ' is-invalid' : '' }}"></div>

					<div class="post-create-hidden-textarea">
						{{ form_widget(form.content, {
                            attr: {
                                class: 'js-post-content'
                            }
                        }) }}
					</div>

					<div class="post-create-field-error">
						{{ form_errors(form.content) }}
					</div>
				</div>

				<div class="post-create-actions post-edit-actions">
					<button type="submit" class="button button-contactForm">
						Сохранить изменения
					</button>

					<a href="{{ path('app_account', { tab: 'posts' }) }}" class="button button-back">
						Назад к публикациям
					</a>

					{% if post.status == 'published' %}
						<a href="{{ path('app_blog_show', { id: post.id, slug: post.slug }) }}" class="button button-view-post">
							Открыть статью
						</a>
					{% endif %}
				</div>
			</article>
		</div>

		{{ form_end(form) }}
	</main>
{% endblock %}

{% block page_scripts %}
	{{ vite_entry_script_tags('post-editor-entry') }}
{% endblock %}
