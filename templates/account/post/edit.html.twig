{% extends 'base.html.twig' %}

{% block title %}Редактирование статьи
{% endblock %}
{% block meta_title %}Редактирование статьи
{% endblock %}
{% block meta_description %}Редактирование публикации
{% endblock %}

{% block page_styles %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('assets/css/post-create.css') }}">
{% endblock %}

{% block body %}
	<main class="main-content bg-white post-create-layout post-edit-layout">
		{{ form_start(form, {
            attr: {
                class: 'js-post-create-form',
                novalidate: 'novalidate'
            }
        }) }}

		<div class="entry-header entry-header-style-2 text-white post-create-hero {% if post.image %}is-filled{% endif %}" id="postHeroPreview" {% if post.image %} style="background-image: url('{{ asset('uploads/posts/' ~ post.image) }}');" {% endif %}>
			<div class="post-create-hero-upload" id="postHeroUpload">
				<div class="post-create-hero-overlay">
					<span class="post-create-hero-plus">+</span>
					<span class="post-create-hero-text">Изменить обложку статьи</span>
					<span class="post-create-hero-subtext">Нажмите, чтобы выбрать новое изображение</span>
				</div>
			</div>
		</div>

		<div class="d-none">
			{{ form_widget(form.imageFile, {
                attr: {
                    class: 'js-post-image-input',
                    accept: 'image/*'
                }
            }) }}
			{{ form_errors(form.imageFile) }}
		</div>

		<div class="container single-content">
			<div class="entry-header entry-header-style-1 mb-50">
				<h1 class="mb-15" style="font-size: 42px;">Редактирование статьи</h1>
				<p class="text-muted mb-30">
					Измените содержимое публикации и сохраните обновления
				</p>

				{{ form_widget(form.title, {
                    attr: {
                        class: 'entry-title-input' ~ (form.title.vars.errors|length ? ' is-invalid' : ''),
                        placeholder: 'Введите заголовок статьи'
                    }
                }) }}

				<div class="post-create-field-error">
					{{ form_errors(form.title) }}
				</div>

				<div class="entry-meta align-items-center meta-2 font-small color-muted mt-20">
					<p class="mb-5">
						<span class="author-avatar">
							<img class="img-circle" src="{{ app.user.avatarUrl }}" alt="{{ app.user.name }}">
						</span>

						<span class="author-name font-weight-bold">
							Автор —
							{{ app.user.name }}
						</span>
					</p>

					<span class="mr-10">Редактирование публикации</span>
					<span class="has-dot">
						{{ post.status == 'published' ? 'Опубликована' : 'Черновик / модерация' }}
					</span>
				</div>

				<div class="post-create-meta-box">
					<div class="post-create-meta-item">
						{{ form_label(form.category) }}
						{{ form_widget(form.category, {
                            attr: {
                                class: 'js-post-category-select' ~ (form.category.vars.errors|length ? ' is-invalid' : '')
                            }
                        }) }}

						<div class="post-create-field-error">
							{{ form_errors(form.category) }}
						</div>
					</div>
				</div>
			</div>

			<article class="entry-wraper mb-50">
				<div class="entry-main-content">
					<label class="form-label mb-10">Текст статьи</label>

					<div class="post-create-toolbar-wrap">
						<div class="post-create-toolbar">
							<button type="button" class="tiptap-btn" data-action="bold" title="Жирный">
								<b>B</b>
							</button>
							<button type="button" class="tiptap-btn" data-action="italic" title="Курсив">
								<i>I</i>
							</button>
							<button type="button" class="tiptap-btn" data-action="h2" title="Заголовок H2">H2</button>
							<button type="button" class="tiptap-btn" data-action="h3" title="Заголовок H3">H3</button>
							<button type="button" class="tiptap-btn" data-action="bulletList" title="Маркированный список">•</button>
							<button type="button" class="tiptap-btn" data-action="orderedList" title="Нумерованный список">1.</button>
							<button type="button" class="tiptap-btn" data-action="blockquote" title="Цитата">❝</button>
							<button type="button" class="tiptap-btn" data-action="undo" title="Отменить">↶</button>
							<button type="button" class="tiptap-btn" data-action="redo" title="Повторить">↷</button>
							<button type="button" class="tiptap-btn" data-action="link" title="Ссылка">🔗</button>
							<button type="button" class="tiptap-btn" data-action="image" title="Изображение">🖼</button>
							<button type="button" class="tiptap-btn" data-action="underline" title="Подчёркивание">
								<u>U</u>
							</button>
							<button type="button" class="tiptap-btn" data-action="alignLeft" title="Выровнять влево">⬅</button>
							<button type="button" class="tiptap-btn" data-action="alignCenter" title="Выровнять по центру">⬌</button>
							<button type="button" class="tiptap-btn" data-action="alignRight" title="Выровнять вправо">➡</button>
						</div>
					</div>

					<input type="file" id="postInlineImageInput" accept="image/*" hidden>

					<div id="postEditor" class="post-create-editor{{ form.content.vars.errors|length ? ' is-invalid' : '' }}"></div>

					<div class="post-create-hidden-textarea">
						{{ form_widget(form.content, {
                            attr: {
                                class: 'js-post-content'
                            }
                        }) }}
					</div>

					<div class="post-create-field-error">
						{{ form_errors(form.content) }}
					</div>
				</div>

				<div class="post-create-actions post-edit-actions">
					<button type="submit" class="button button-contactForm">
						Сохранить изменения
					</button>

					<a href="{{ path('app_account', { tab: 'posts' }) }}" class="button button-dark-outline">
						Назад к публикациям
					</a>

					{% if post.status == 'published' %}
						<a href="{{ path('app_blog_show', { id: post.id, slug: post.slug }) }}" class="button button-view-post">
							Открыть статью
						</a>
					{% endif %}
				</div>
			</article>
		</div>

		{{ form_end(form) }}
	</main>
{% endblock %}

{% block page_scripts %}{% endblock %}
