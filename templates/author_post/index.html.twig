{% extends 'base.html.twig' %}

{% block body %}
	<!-- Start Main content -->
	<main
		class="main-content bg-white">
		<!--archive header-->
		<div class="archive-header pt-50 pb-50 bg-3 mb-50">
			<div class="container">
				<div class="widget-header-1 font-primary mb-30">
					<span class="widget-subtitle position-relative text-primary">
						<span class="divider-separator"></span>Автор
					</span>
					<h2 class="widget-title mt-5 mb-30">
						{{ author.name }}
						<sup>
							{% set count = posts|length %}
							{{ count }}
							{{ count|ru_plural('пост', 'поста', 'постов') }}
						</sup>
					</h2>
				</div>
				<div class="breadcrumb">
					<a href="{{ path('home') }}" rel="nofollow">Home</a>
					<span></span>
					{{ author.name }}
				</div>
			</div>
		</div>

		<div
			class="container mb-50">
			<!--Loop Masonry-->
			<div class="grid row mb-30">
				<div class="grid-sizer"></div>

				{% for post in posts %}
					<article class="grid-item col pb-50 wow fadeIn animated">
						<figure class="mb-20">
							<a href="{{ path('app_blog_show', { slug: post.slug }) }}">
								{% if post.image %}
									<img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
								{% else %}
									<img src="{{ asset('assets/imgs/posts/thumb-11.jpg') }}" alt="{{ post.title }}">
								{% endif %}
							</a>
						</figure>

						<div class="post-meta mb-10 font-primary text-uppercase">
							{% if post.category %}
								<span>
									<a href="#">{{ post.category.name }}</a>
								</span>
							{% endif %}
						</div>

						<h5 class="post-title">
							<a href="{{ path('app_blog_show', { slug: post.slug }) }}">
								{{ post.title }}
							</a>
						</h5>

						<div class="entry-meta meta-1 font-x-small color-grey mt-10 pb-10">
							<span class="post-on">{{ post.createdAt ? post.createdAt|date('d.m.Y H:i') : '' }}</span>
						</div>

						{% if post.content %}
							<p>
								{{ post.content|striptags|slice(0, 120) }}
								{% if post.content|striptags|length > 120 %}...
								{% endif %}
							</p>
						{% endif %}
					</article>
				{% else %}
					<div class="col-12">
						<p>У этого автора пока нет публикаций.</p>
					</div>
				{% endfor %}
			</div>


		</div>


	</main>
	<!-- End Main content -->
{% endblock %}
