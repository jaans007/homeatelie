{% extends 'base.html.twig' %}

{% block title %}Трендовые публикации{% endblock %}

{% block body %}
    <!-- Start Main content -->
    <main class="main-content bg-white">
        <!-- archive header -->
        <div class="archive-header pt-50 pb-50 bg-3 mb-50">
            <div class="container">
                <div class="widget-header-1 font-primary mb-30">
                    <span class="widget-subtitle position-relative text-primary">
                        <span class="divider-separator"></span>
                        Популярное за 30 дней
                    </span>
                    <h2 class="widget-title mt-5 mb-30">
                        Популярные публикации
                        <sup>
                        {% set count = posts|length %}
                        {{ count }}
                        {{ count|ru_plural('публикация', 'публикации', 'публикаций') }}
                        </sup>
                    </h2>
                </div>
                <div class="breadcrumb">
                    <a href="{{ path('home') }}" rel="nofollow">Главная</a>
                    <span></span> Трендовые публикации
                </div>
            </div>
        </div>

        <div class="container mb-50">
            <div class="sidebar-widget post-module-1">
                <div class="row mb-50">
                    {% for post in posts %}
                        <article class="col-lg-3 col-md-6 mb-50 wow animated fadeIn">
                            <figure class="mb-20">
                                <a href="{{ path('app_blog_show', {id: post.id, slug: post.slug}) }}">
                                    {% if post.image %}
                                        <img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
                                    {% else %}
                                        <img src="{{ asset('assets/imgs/placeholder.jpg') }}" alt="{{ post.title }}">
                                    {% endif %}
                                </a>
                            </figure>

                            <div class="post-meta mb-10 font-primary text-uppercase">
                                <span>
                                    {% if post.category %}
                                        <a href="{{ path('app_category_show', {slug: post.category.slug}) }}">
                                            {{ post.category.name }}
                                        </a>
                                    {% else %}
                                        <span>Без категории</span>
                                    {% endif %}
                                </span>
                            </div>

                            <h5 class="post-title mb-10">
                                <a href="{{ path('app_blog_show', {id: post.id, slug: post.slug}) }}">
                                    {{ post.title }}
                                </a>
                            </h5>

                            <div class="entry-meta meta-1 font-x-small color-grey">
                                <span class="post-on">{{ post.createdAt|date('d.m.Y') }}</span>
                                <span class="mx-2">|</span>
                                <span class="views-count">
                                    <i data-lucide="eye" style="width: 14px; height: 14px; stroke-width: 1.8; vertical-align: -2px;"></i>
                                    {{ post.viewsCount }}
                                </span>
                            </div>
                        </article>
                    {% else %}
                        <div class="col-12">
                            <div class="alert alert-light text-center">
                                За последние 30 дней трендовых публикаций пока нет.
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="view-more text-center wow animated fadeIn">
                    <a href="{{ path('app_blog') }}" class="btn btn-outline-primary border-radius-0 font-weight-thin">
                        Смотреть все публикации
                    </a>
                </div>
            </div>
        </div>
    </main>
    <!-- End Main content -->
{% endblock %}
