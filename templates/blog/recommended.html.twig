{% extends 'base.html.twig' %}

{% block title %}Рекомендуемые публикации{% endblock %}

{% block body %}
    <main class="main-content bg-white">
        <div class="archive-header pt-50 pb-50 bg-1 mb-50">
            <div class="container">
                <div class="widget-header-1 font-primary mb-30">
                    <span class="widget-subtitle position-relative text-primary">
                        <span class="divider-separator"></span>
                        Рекомендуемое
                    </span>
                    <h2 class="widget-title mt-5 mb-30">Рекомендуемые публикации</h2>
                </div>
                <div class="breadcrumb">
                    <a href="{{ path('home') }}" rel="nofollow">Главная</a>
                    <span></span> Рекомендуемые публикации
                </div>
            </div>
        </div>

        <div class="container mb-50">
            <div class="sidebar-widget post-module-1">
                <div id="recommended-posts-list" class="row mb-50">
                    {% include 'blog/_recommended_posts.html.twig' with { posts: posts } %}
                </div>

                {% if posts is empty %}
                    <div class="alert alert-light text-center">
                        Пока нет рекомендуемых публикаций.
                    </div>
                {% endif %}

                {% if hasMore %}
                    <div class="view-more text-center wow animated fadeIn">
                        <button
                            id="load-more-recommended"
                            class="btn btn-outline-primary border-radius-0 font-weight-thin"
                            data-page="{{ currentPage + 1 }}"
                            data-url="{{ path('app_blog_recommended_load_more') }}"
                        >
                            Загрузить ещё
                        </button>
                    </div>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const button = document.getElementById('load-more-recommended');
            const container = document.getElementById('recommended-posts-list');

            if (!button || !container) {
                return;
            }

            button.addEventListener('click', async function () {
                const page = this.dataset.page;
                const url = this.dataset.url + '?page=' + page;

                this.disabled = true;
                this.textContent = 'Загрузка...';

                try {
                    const response = await fetch(url, {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        throw new Error('Ошибка загрузки');
                    }

                    const data = await response.json();

                    container.insertAdjacentHTML('beforeend', data.html);

                    if (window.lucide) {
                        lucide.createIcons();
                    }

                    if (data.hasMore) {
                        this.dataset.page = data.nextPage;
                        this.disabled = false;
                        this.textContent = 'Загрузить ещё';
                    } else {
                        this.remove();
                    }
                } catch (error) {
                    this.disabled = false;
                    this.textContent = 'Попробовать снова';
                    console.error(error);
                }
            });
        });
    </script>
{% endblock %}
