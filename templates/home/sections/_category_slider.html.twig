<div class="container mb-50">
    <div class="sidebar-widget">
        <div class="widget-header-1 font-primary mb-30">
            <span class="widget-subtitle position-relative text-primary">
                <span class="divider-separator"></span>
                {{ categorySliderCategory ? categorySliderCategory.name : 'Категория' }}
            </span>

            <h2 class="widget-title mt-5 mb-30">
                {% if categorySliderCategory %}
                    Популярное в категории «{{ categorySliderCategory.name }}»
                {% else %}
                    Популярное в категории
                {% endif %}
            </h2>
        </div>

        <div class="swiper swiper-container post-slider-4">
            <div class="swiper-wrapper">
                {% for post in categorySliderPosts %}
                    <div class="swiper-slide">
                        <article>
                            <figure class="mb-20">
                                <a href="{{ path('app_blog_show', { id: post.id, slug: post.slug }) }}">
                                    {% if post.image %}
                                        <img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
                                    {% else %}
                                        <img src="{{ asset('assets/imgs/theme/placeholder.jpg') }}" alt="{{ post.title }}">
                                    {% endif %}
                                </a>
                            </figure>

                            <div class="post-meta mb-10 font-primary text-uppercase">
                                <span>
                                    {% if post.category %}
                                        <a href="{{ path('app_category_show', { slug: post.category.slug }) }}">
                                            {{ post.category.name }}
                                        </a>
                                    {% endif %}
                                </span>
                            </div>

                            <h5 class="post-title">
                                <a href="{{ path('app_blog_show', { id: post.id, slug: post.slug }) }}">
                                    {{ post.title }}
                                </a>
                            </h5>
                        </article>
                    </div>
                {% else %}
                    <div class="swiper-slide">
                        <article>
                            <h5 class="post-title">Публикации не найдены</h5>
                        </article>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
