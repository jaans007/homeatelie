{% extends 'base.html.twig' %}

{% block title %}Новый пароль
{% endblock %}

{% block body %}
	<main class="main-content bg-white">
		<div class="container mb-50 pt-120 pb-80 text-center">
			<div class="entry-page-wraper mb-120">

				<h2 class="font-secondary">Новый пароль</h2>
				<p class="w-50 mx-auto text-muted">
					Введите новый пароль для вашего аккаунта
				</p>

				<div class="row">
					<div class="col-md-4 mx-auto">

						{{ form_start(resetForm, {
                        attr: {
                            class: 'form-contact comment_form mt-20'
                        }
                    }) }}

						<div class="row">

							<div class="col-12 mb-15">
								<div class="form-group text-start">
									{{ form_label(resetForm.plainPassword.first, 'Новый пароль') }}
									{{ form_widget(resetForm.plainPassword.first, {
                                        attr: {
                                            class: 'form-control mt-5',
                                            placeholder: '*********'
                                        }
                                    }) }}
									{{ form_errors(resetForm.plainPassword.first) }}
								</div>
							</div>

							<div class="col-12 mb-15">
								<div class="form-group text-start">
									{{ form_label(resetForm.plainPassword.second, 'Повторите пароль') }}
									{{ form_widget(resetForm.plainPassword.second, {
                                        attr: {
                                            class: 'form-control mt-5',
                                            placeholder: '*********'
                                        }
                                    }) }}
									{{ form_errors(resetForm.plainPassword.second) }}
								</div>
							</div>

						</div>

						<div class="form-group mt-30 text-start">
							<button type="submit" class="button button-contactForm mt-5 w-100">
								Сохранить пароль
							</button>
						</div>

						{{ form_end(resetForm) }}

						<p class="mt-30 mb-10 text-center">
							<a href="{{ path('app_login') }}">Вернуться ко входу</a>
						</p>

					</div>
				</div>

			</div>
		</div>
	</main>
{% endblock %}
